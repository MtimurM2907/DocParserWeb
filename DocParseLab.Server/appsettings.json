{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=pdf_parser_db;Username=postgres;Password=1234"
  },
  "Jwt": {
    "Key": "super_secret_development_key_change_me_in_production_minimum_32_chars",
    "Issuer": "PdfParserWeb",
    "Audience": "PdfParserWebClient",
    "ExpirationMinutes": 720
  },
  "GigaChat": {
    "AuthUrl": "https://ngw.devices.sberbank.ru:9443/api/v2/oauth",
    "ApiUrl": "https://gigachat.devices.sberbank.ru/api/v1/chat/completions",
    "Authorization": "",
    "ClientId": "",
    "ClientSecret": "",
    "Scope": "GIGACHAT_API_PERS",
    "Model": "GigaChat"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "your_email@example.com",
    "Password": "YOUR_SMTP_APP_PASSWORD",
    "FromEmail": "your_email@example.com",
    "FromName": "DocParseLab"
  },
  "Ocr": {
    "Enabled": true,
    "Languages": "rus",
    "TessdataPath": "Resources/Tessdata",
    "MinTextCharsToSkipOcr": 80,
    "MaxImagesPerPage": 6,
    "OcrOnSuspiciousTextLayer": true,
    "RenderWidth": 3000,
    "RenderHeight": 4200,
    "PageParallelism": 3,
    "MinImageWidthForOcr": 600,
    "MinImageHeightForOcr": 600,
    "ScannedPdfRenderOnly": true,
    "ApplyHunspellCorrection": true,
    "UseDualTesseractPass": false
  },
  "Ldap": {
    "Enabled": false,
    "Host": "ldap.example.com",
    "Port": 389,
    "UseSsl": false,
    "BaseDn": "dc=example,dc=com",
    "BindDnTemplate": "{email}"
  },
  "FileScan": {
    "Enabled": true,
    "MaxFileSizeBytes": 52428800,
    "AllowedExtensions": [ ".pdf", ".docx" ]
  },
  "Enterprise": {
    "WebhookUrl": "",
    "WebhookSecret": "",
    "BatchApiKey": "",
    "EnableAudit": true,
    "Checklists": [
      {
        "Id": "contract_basic",
        "Title": "Договор: базовые заголовки",
        "RequiredPhrases": [ "Договор", "Стороны" ]
      }
    ]
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:5000"
      }
    },
    "LimitMaxRequestBodySize": 52428800
  }
}
